def tim_max(a):
    max_value = a[0]
    vi_tri = 0
    for i in range(len(a)):
        if a[i] > max_value:
            max_value = a[i]
            vi_tri = i
    return max_value, vi_tri
a = [12, 5, 9, 30, 18]
maxx, vitri = tim_max(a)
print("Gia tri lon nhat:", maxx)
print("Vi tri:", vitri)